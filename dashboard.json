{
    "scriptsDir": "scripts/linux",
    "commandSets": [
        {
            "name": "Build",
            "commands": [
                { "label": "Setup Dependencies", "script": "setup/setup-deps.sh" },
                { "label": "Format Code", "script": "build/format-all-code.sh" },
                { "label": "Build help", "script": "build/generate-kernel-docs.sh" },
                { "label": "Show help", "script": "xdg-open doc/generated/kernel/html/index.html" },
                { "label": "Start server", "script": "net/start-server.sh" },
                { "label": "Clean log & build", "script": "rimraf log build" },

                { "label": "x86-32 build--------" },

                { "label": "Build 32 MBR Rel", "script": "scripts/linux/build/build --arch x86-32 --fs ext2 --release --clean" },
                { "label": "Build 32 MBR Rel ++", "script": "scripts/linux/build/build --arch x86-32 --fs ext2 --release" },
                { "label": "Build 32 MBR Deb", "script": "scripts/linux/build/build --arch x86-32 --fs ext2 --debug --clean" },
                { "label": "Build 32 MBR Deb ++", "script": "scripts/linux/build/build --arch x86-32 --fs ext2 --debug" },
                { "label": "Build 32 MBR Deb Prof", "script": "scripts/linux/build/build --arch x86-32 --fs ext2 --debug --profiling --clean" },
                { "label": "Build 32 MBR Deb Split", "script": "scripts/linux/build/build --arch x86-32 --fs ext2 --debug --split --clean" },

                { "label": "Build 32 System Data View", "script": "scripts/linux/build/build --arch x86-32 --fs ext2 --system-data-view --clean" },
                { "label": "Build 32 VESA Test Payload", "script": "make -C boot-mbr BUILD_CORE_NAME=x86-32-mbr-debug BUILD_IMAGE_NAME=x86-32-mbr-debug-ext2 PAYLOAD_SOURCE=test-payloads/vesa-test.c ARCH=x86-32 clean install-vbr-payload" },
                { "label": "Build 32 Dumper Payload", "script": "make -C boot-mbr BUILD_CORE_NAME=x86-32-mbr-debug BUILD_IMAGE_NAME=x86-32-mbr-debug-ext2 PAYLOAD_SOURCE=test-payloads/dumper*.c ARCH=x86-32 clean install-vbr-payload" },
                { "label": "Build 32 BIOS Keyboard Payload", "script": "make -C boot-mbr BUILD_CORE_NAME=x86-32-mbr-debug BUILD_IMAGE_NAME=x86-32-mbr-debug-ext2 PAYLOAD_SOURCE=test-payloads/bios-keyboard.c ARCH=x86-32 install-vbr-payload" },

                { "label": "x86-32 run----------" },

                { "label": "Start 32 QEMU MBR Rel", "script": "scripts/linux/run/run --arch x86-32 --fs ext2 --release" },
                { "label": "Start 32 QEMU MBR Deb", "script": "scripts/linux/run/run --arch x86-32 --fs ext2 --debug" },
                { "label": "Start 32 QEMU MBR Deb RTL8139", "script": "scripts/linux/run/run --arch x86-32 --fs ext2 --debug --net-card rtl8139" },
                { "label": "Start 32 QEMU MBR Deb 2 NICs", "script": "scripts/linux/run/run --arch x86-32 --fs ext2 --debug --net-card e1000 --net-card rtl8139" },
                { "label": "Start 32 QEMU VESA Test", "script": "scripts/linux/run/run --arch x86-32 --build-core-name x86-32-mbr-debug --build-image-name x86-32-mbr-debug-ext2 --debug --no-nvme --no-usb3" },
                { "label": "Start 32 QEMU Dumper Test", "script": "scripts/linux/run/run --arch x86-32 --build-core-name x86-32-mbr-debug --build-image-name x86-32-mbr-debug-ext2 --debug --no-nvme --no-usb3" },

                { "label": "x86-64 build--------" },

                { "label": "Build 64 MBR Rel", "script": "scripts/linux/build/build --arch x86-64 --fs ext2 --release --clean" },
                { "label": "Build 64 MBR Rel ++", "script": "scripts/linux/build/build --arch x86-64 --fs ext2 --release" },
                { "label": "Build 64 MBR Deb", "script": "scripts/linux/build/build --arch x86-64 --fs ext2 --debug --clean" },
                { "label": "Build 64 MBR Deb ++", "script": "scripts/linux/build/build --arch x86-64 --fs ext2 --debug" },
                { "label": "Build 64 MBR Deb Split", "script": "scripts/linux/build/build --arch x86-64 --fs ext2 --debug --split --clean" },

                { "label": "x86-64 UEFI build--------" },

                { "label": "Build 64 UEFI Rel", "script": "scripts/linux/build/build --arch x86-64 --fs ext2 --release --uefi --clean" },
                { "label": "Build 64 UEFI Rel ++", "script": "scripts/linux/build/build --arch x86-64 --fs ext2 --release --uefi" },
                { "label": "Build 64 UEFI Deb", "script": "scripts/linux/build/build --arch x86-64 --fs ext2 --debug --uefi --clean" },
                { "label": "Build 64 UEFI Deb ++", "script": "scripts/linux/build/build --arch x86-64 --fs ext2 --debug --uefi" },
                { "label": "Build 64 UEFI Deb Split", "script": "scripts/linux/build/build --arch x86-64 --fs ext2 --debug --split --uefi --boot-stage-markers --clean" },

                { "label": "x86-64 run----------" },

                { "label": "Start 64 QEMU MBR Rel", "script": "scripts/linux/run/run --arch x86-64 --fs ext2 --release" },
                { "label": "Start 64 QEMU MBR Deb", "script": "scripts/linux/run/run --arch x86-64 --fs ext2 --debug" },
                { "label": "Start 64 QEMU MBR Deb Split", "script": "scripts/linux/run/run --arch x86-64 --fs ext2 --debug --split" },
                { "label": "Start 64 QEMU UEFI Rel", "script": "scripts/linux/run/run --arch x86-64 --fs ext2 --release --uefi" },
                { "label": "Start 64 QEMU UEFI Deb", "script": "scripts/linux/run/run --arch x86-64 --fs ext2 --debug --uefi" },
                { "label": "Start 64 QEMU UEFI Deb Split", "script": "scripts/linux/run/run --arch x86-64 --fs ext2 --debug --uefi --split" }
            ]
        },
        {
            "name": "Tests",
            "commands": [
                { "label": "smoke tests---------" },

                { "label": "Smoke test global (all targets)", "script": "bash scripts/linux/test/smoke-test-global.sh" },
                { "label": "Smoke test x86-32", "script": "bash scripts/linux/test/smoke-test-global.sh --only x86-32" },
                { "label": "Smoke test x86-64", "script": "bash scripts/linux/test/smoke-test-global.sh --only x86-64" },
                { "label": "Smoke test x86-64 UEFI", "script": "bash scripts/linux/test/smoke-test-global.sh --only x86-64-uefi" }
            ]
        },
        {
            "name": "Checks",
            "commands": [
                { "label": "Check code constraints", "script": "bash scripts/linux/checks/check-code.sh" },
                { "label": "Check structure naming", "script": "bash scripts/linux/checks/check-struct-naming.sh" }
            ]
        }
    ],
    "settings": {
        "enableCommandHistory": true,
        "persistLogs": false,
        "notifyOnExit": true,
        "showCustomCommand": false,
        "showLogWindow": false,
        "renderThrottleMs": 50,
        "maxLogLines": 1000,
        "sidebarMinWidth": 32
    },
    "events": {
        "onDashboardStart": [
            {
                "action": "killProcess",
                "parameters": [
                    "qemu-system-i386"
                ]
            },
            {
                "action": "killProcess",
                "parameters": [
                    "qemu-system-x86-64"
                ]
            }
        ],
        "beforeStartProcess": []
    }
}
